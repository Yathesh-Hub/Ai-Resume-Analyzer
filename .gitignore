# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
*/node_modules/
**/node_modules/

# ── Environment & Secrets ─────────────────────────────────────────────────────
# Never commit .env files — they contain API keys, DB passwords, JWT secrets
.env
.env.*
!.env.example        # only the example template is safe to commit
*.env
backend/.env
frontend/.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
.env.backup

# SSL / TLS certificates and private keys
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.jks

# Secret / credential files
secrets/
credentials/
*.credentials
serviceAccountKey.json
firebase-adminsdk*.json
google-credentials*.json

# ── Build Outputs ─────────────────────────────────────────────────────────────
build/
dist/
out/
*/build/
*/dist/
frontend/build/
backend/dist/
.next/
.nuxt/
.svelte-kit/

# ── Uploaded Files & User-Generated Content ───────────────────────────────────
# Keep directory structure but never commit actual uploaded files
uploads/*
*/uploads/*
backend/uploads/*
backend/uploads/jd-temp/
!uploads/.gitkeep
!*/uploads/.gitkeep
!backend/uploads/.gitkeep

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# ── Testing & Coverage ────────────────────────────────────────────────────────
coverage/
*.coverage
.nyc_output/
.jest/
jest_html_reporters-attach/

# ── OS & System Files ─────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
*~

# ── IDE & Editor ──────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json   # safe to share recommended extensions
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/
*.code-workspace

# ── Package Managers ──────────────────────────────────────────────────────────
.pnpm-store/
.yarn/
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.npm/
.pnp.*

# ── Misc Cache & Temp ─────────────────────────────────────────────────────────
.cache/
.temp/
.tmp/
tmp/
temp/
*.pid
*.seed
*.pid.lock
*.tgz
*.tar.gz
.eslintcache
.stylelintcache
.parcelcache
.node_repl_history
