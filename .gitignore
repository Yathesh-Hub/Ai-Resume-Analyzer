# Uploads and user-generated content
# Ignore all files in uploads directories but keep the directory structure
uploads/*
*/uploads/*
backend/uploads/*

# Keep .gitkeep files to track empty directories
!uploads/.gitkeep
!*/uploads/.gitkeep
!backend/uploads/.gitkeep

